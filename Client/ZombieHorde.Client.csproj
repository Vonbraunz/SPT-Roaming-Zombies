<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <OutputType>Library</OutputType>
    <AssemblyName>ZombieHorde.Client</AssemblyName>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <Deterministic>true</Deterministic>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>

    <!-- Output -->
    <OutputPath>bin\$(Configuration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>

    <!-- Mod Info -->
    <ModName>ZombieHorde</ModName>
  </PropertyGroup>

  <!-- Directories -->
  <PropertyGroup>
    <TarkovDir Condition=" '$(TarkovDir)' == '' ">C:\SPT\ModTest\</TarkovDir>
    <TarkovPluginsSPTDir>$(TarkovDir)BepInEx\plugins\spt\</TarkovPluginsSPTDir>
    <TarkovManagedDir>$(TarkovDir)EscapeFromTarkov_Data\Managed\</TarkovManagedDir>
    <TarkovBepInExCoreDir>$(TarkovDir)BepInEx\core\</TarkovBepInExCoreDir>
  </PropertyGroup>

  <!-- References -->
  <ItemGroup>
    <Reference Include="0Harmony">
      <HintPath>$(TarkovBepInExCoreDir)0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="BepInEx">
      <HintPath>$(TarkovBepInExCoreDir)BepInEx.dll</HintPath>
    </Reference>
    <Reference Include="spt-reflection">
      <HintPath>$(TarkovPluginsSPTDir)spt-reflection.dll</HintPath>
    </Reference>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(TarkovManagedDir)Assembly-CSharp.dll</HintPath>
    </Reference>
    <Reference Include="Comfort">
      <HintPath>$(TarkovManagedDir)Comfort.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>$(TarkovManagedDir)UnityEngine.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(TarkovManagedDir)UnityEngine.CoreModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.AudioModule">
      <HintPath>$(TarkovManagedDir)UnityEngine.AudioModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.UnityWebRequestModule">
      <HintPath>$(TarkovManagedDir)UnityEngine.UnityWebRequestModule.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.UnityWebRequestAudioModule">
      <HintPath>$(TarkovManagedDir)UnityEngine.UnityWebRequestAudioModule.dll</HintPath>
    </Reference>
  </ItemGroup>

  <!-- Post-Build: Create release ZIP + Deploy to SPT -->
  <Target Name="PostBuild" AfterTargets="Build">
    <ItemGroup>
      <ClientDLL Include="$(TargetPath)" />
      <ClientLicense Include="$(ProjectDir)LICENSE" Condition="Exists('$(ProjectDir)LICENSE')" />
      <AudioFiles Include="$(ProjectDir)Audio\*.*" Condition="Exists('$(ProjectDir)Audio\')" />
      <ServerDLL Include="$(ProjectDir)..\Server\bin\$(Configuration)\ZombieHorde\ZombieHorde.Server.dll" />
      <ServerConfig Include="$(ProjectDir)..\Server\bin\$(Configuration)\ZombieHorde\config.json" />
    </ItemGroup>

    <!-- ============ Create release ZIP for SPT Forge (always runs first) ============ -->
    <RemoveDir Directories="$(ProjectDir)release" />

    <Copy SourceFiles="@(ClientDLL);@(ClientLicense);@(AudioFiles)"
          DestinationFolder="$(ProjectDir)release\$(ModName)\BepInEx\plugins\$(ModName)\" />

    <Copy SourceFiles="@(ServerDLL);@(ServerConfig)"
          DestinationFolder="$(ProjectDir)release\$(ModName)\SPT\user\mods\$(ModName)\" />

    <ZipDirectory SourceDirectory="$(ProjectDir)release\$(ModName)\"
                  DestinationFile="$(ProjectDir)release\$(ModName).zip" />

    <Message Importance="high" Text="✓ Release packaged: release\$(ModName).zip" />

    <!-- ============ Deploy to local SPT install (best-effort — may fail if SPT is running) ============ -->
    <Copy SourceFiles="@(ClientDLL);@(ClientLicense);@(AudioFiles)"
          DestinationFolder="$(TarkovDir)BepInEx\plugins\$(ModName)\"
          ContinueOnError="true" />

    <Copy SourceFiles="@(ServerDLL);@(ServerConfig)"
          DestinationFolder="$(TarkovDir)SPT\user\mods\$(ModName)\"
          ContinueOnError="true" />
  </Target>

</Project>
